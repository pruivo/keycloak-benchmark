<infinispan
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="urn:infinispan:config:14.0 https://infinispan.org/schemas/infinispan-config-14.0.xsd
                        urn:org:jgroups http://www.jgroups.org/schema/jgroups-5.2.xsd"
        xmlns="urn:infinispan:config:14.0">

    <jgroups>
        <stack name="relay-tunnel" extends="udp">
            <TUNNEL xmlns="urn:org:jgroups"
                    bind_addr="${jgroups.relay.bind.address:SITE_LOCAL}"
                    bind_port="${jgroups.relay.bind.port:0}"
                    gossip_router_hosts="${env.jgroups.xsite.gossiprouters}"
                    port_range="0"
                    stack.combine="REPLACE"
                    stack.position="UDP"
            />
            <!-- we are unable to use FD_SOCK with openshift -->
            <FD_SOCK2 stack.combine="REMOVE" />
        </stack>
        <stack name="xsite" extends="kubernetes">
            <relay.RELAY2 xmlns="urn:org:jgroups"
                          site="${env.jgroups.xsite.name}"
                          max_site_masters="1" />
            <remote-sites default-stack="relay-tunnel">
                <remote-site name="${env.jgroups.xsite.name}" />
            </remote-sites>
        </stack>
    </jgroups>

    <!-- the statistics="true" attribute is not part of the original KC config and was added by Keycloak Benchmark -->
    <cache-container name="keycloak" statistics="true">
        <transport lock-timeout="60000" stack="xsite"/>
        <local-cache name="realms" simple-cache="true" statistics="true">
            <encoding>
                <key media-type="application/x-java-object"/>
                <value media-type="application/x-java-object"/>
            </encoding>
            <memory max-count="10000"/>
        </local-cache>
        <local-cache name="users" simple-cache="true" statistics="true">
            <encoding>
                <key media-type="application/x-java-object"/>
                <value media-type="application/x-java-object"/>
            </encoding>
            <memory max-count="10000"/>
        </local-cache>
        <distributed-cache name="sessions" owners="2" statistics="true">
            <expiration lifespan="-1"/>
        </distributed-cache>
        <distributed-cache name="authenticationSessions" owners="2" statistics="true">
            <expiration lifespan="-1"/>
        </distributed-cache>
        <distributed-cache name="offlineSessions" owners="2" statistics="true">
            <expiration lifespan="-1"/>
        </distributed-cache>
        <distributed-cache name="clientSessions" owners="2" statistics="true">
            <expiration lifespan="-1"/>
        </distributed-cache>
        <distributed-cache name="offlineClientSessions" owners="2" statistics="true">
            <expiration lifespan="-1"/>
        </distributed-cache>
        <distributed-cache name="loginFailures" owners="2" statistics="true">
            <expiration lifespan="-1"/>
        </distributed-cache>
        <local-cache name="authorization" simple-cache="true" statistics="true">
            <encoding>
                <key media-type="application/x-java-object"/>
                <value media-type="application/x-java-object"/>
            </encoding>
            <memory max-count="10000"/>
        </local-cache>
        <replicated-cache name="work" statistics="true">
            <expiration lifespan="-1"/>
        </replicated-cache>
        <local-cache name="keys" simple-cache="true" statistics="true">
            <encoding>
                <key media-type="application/x-java-object"/>
                <value media-type="application/x-java-object"/>
            </encoding>
            <expiration max-idle="3600000"/>
            <memory max-count="1000"/>
        </local-cache>
        <distributed-cache name="actionTokens" owners="2" statistics="true">
            <encoding>
                <key media-type="application/x-java-object"/>
                <value media-type="application/x-java-object"/>
            </encoding>
            <expiration max-idle="-1" lifespan="-1" interval="300000"/>
            <memory max-count="-1"/>
        </distributed-cache>
    </cache-container>
</infinispan>
